# Copy to .env.test and fill in real values.
# WARNING: ALL TABLES in BQ_TEST_DATASET will be dropped before each test run.

# Path to a Google Cloud service account JSON with BigQuery access.
# If GOOGLE_APPLICATION_CREDENTIALS is already set in your shell, this is optional.
BQ_TEST_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# BigQuery project to run tests against (use a dedicated test project).
BQ_TEST_PROJECT=my-test-project-id

# BigQuery dataset where test tables will be created and destroyed.
BQ_TEST_DATASET=bq_assist_integration_tests

# BigQuery region (default: region-eu).
BQ_TEST_REGION=region-eu
